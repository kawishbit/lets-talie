# ── Build ───────────────────────────────────────────────────────────────────────
# Build-time only (read in astro.config.ts, not available at runtime).
# "vercel"  -> @astrojs/vercel serverless build, for the public demo deploy.
# unset/any other value -> @astrojs/node standalone build, for Docker / bare-metal.
# ADAPTER=vercel

# ── Auth ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL where the app is hosted (no trailing slash)
BETTER_AUTH_URL=http://localhost:30001

# ── SMTP ────────────────────────────────────────────────────────────────────────
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
# Set to true for port 465 (SSL), false for port 587 (STARTTLS)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ── App ─────────────────────────────────────────────────────────────────────────
# ISO 4217 currency code used for formatting monetary values (e.g. USD, EUR, GBP)
PUBLIC_CURRENCY_CODE=USD

# ── Demo Mode ───────────────────────────────────────────────────────────────────
# For the public read-only demo deploy only — leave unset for self-hosting.
# Must be "true" at BUILD time to take effect (it's a PUBLIC_ var, inlined into
# the client bundle) — set it before `bun run build` / as a Vercel project env var,
# not just at container runtime.
# PUBLIC_DEMO_MODE=true

# Email of the seeded demo account (see src/db/seed-demo.ts / bun run seed:demo).
# Required whenever PUBLIC_DEMO_MODE=true.
# DEMO_USER_EMAIL=demo@yourdomain.com

# ── Database ────────────────────────────────────────────────────────────────────
# Not required when using docker-compose — set automatically.
# Required only when running without Docker.
DATABASE_URL=postgres://user:password@host:5432/dbname

# ── Docker Compose only ────────────────────────────────────────────────────────
# Host-side port overrides — change these if 30001 or 5433 are already taken
# on your machine. Container-internal ports are unaffected.
# APP_PORT=30001
# DB_PORT=5433
# DB_TEST_PORT=5434

# ── Integration / E2E tests (bun run test:integration / test:e2e) ───────────────
# Dedicated test DB + SMTP catcher, isolated from dev data. Start them with:
#   docker compose --profile test up -d db-test mailpit-test
# TEST_DATABASE_URL=postgresql://letstalie_test:letstalie_test@localhost:5434/letstalie_test
# TEST_APP_PORT=30099
# TEST_E2E_PORT=30098
# MAILPIT_TEST_SMTP_PORT=1026
# MAILPIT_TEST_HTTP_PORT=8026