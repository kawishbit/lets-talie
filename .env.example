# ── Auth ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL where the app is hosted (no trailing slash)
BETTER_AUTH_URL=http://localhost:30001

# ── SMTP ────────────────────────────────────────────────────────────────────────
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
# Set to true for port 465 (SSL), false for port 587 (STARTTLS)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ── App ─────────────────────────────────────────────────────────────────────────
# ISO 4217 currency code used for formatting monetary values (e.g. USD, EUR, GBP)
PUBLIC_CURRENCY_CODE=USD

# ── Database ────────────────────────────────────────────────────────────────────
# Not required when using docker-compose — set automatically.
# Required only when running without Docker.
DATABASE_URL=postgres://user:password@host:5432/dbname