{
	"name": "lets-talie",
	"type": "module",
	"version": "0.0.1",
	"engines": {
		"bun": ">=1.0.0"
	},
	"scripts": {
		"dev": "bunx --bun astro dev",
		"build": "bunx --bun astro build",
		"preview": "bunx --bun astro preview",
		"migrate": "bunx --bun drizzle-kit migrate",
		"start": "bun ./dist/server/entry.mjs",
		"seed:demo": "bun run src/db/seed-demo.ts",
		"format": "bunx --bun @biomejs/biome format --write",
		"lint": "bunx --bun @biomejs/biome lint",
		"check": "bunx --bun @biomejs/biome check",
		"check:fix": "bunx --bun @biomejs/biome check --fix",
		"astro": "bunx --bun astro",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:integration": "bun run src/__integration__/run-integration.ts",
		"test:e2e": "bun run src/__integration__/e2e/run-e2e.ts"
	},
	"dependencies": {
		"@astrojs/node": "^11.0.2",
		"@astrojs/vercel": "^11.0.2",
		"@astrojs/vue": "^7.0.1",
		"@better-auth/drizzle-adapter": "^1.6.23",
		"@tailwindcss/vite": "^4.3.2",
		"@vite-pwa/astro": "^1.2.0",
		"astro": "^7.0.6",
		"better-auth": "^1.6.23",
		"drizzle-orm": "^1.0.0-rc.4",
		"nodemailer": "^9.0.3",
		"tailwindcss": "^4.3.2",
		"vue": "^3.5.39"
	},
	"devDependencies": {
		"@astrojs/ts-plugin": "^1.10.10",
		"@biomejs/biome": "2.5.2",
		"@playwright/test": "^1.61.1",
		"@testcontainers/postgresql": "^12.0.4",
		"@testing-library/vue": "^8.1.0",
		"@types/bun": "^1.3.14",
		"@types/nodemailer": "^8.0.1",
		"@vitest/coverage-v8": "^4.1.10",
		"@vue/test-utils": "^2.4.11",
		"drizzle-kit": "^1.0.0-rc.4",
		"jsdom": "^29.1.1",
		"testcontainers": "^12.0.4",
		"vitest": "^4.1.10"
	}
}
