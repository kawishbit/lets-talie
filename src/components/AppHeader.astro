---
import IconMenu from "~icons/lucide/menu";
import IconMoon from "~icons/lucide/moon";
import IconSun from "~icons/lucide/sun";
import IconX from "~icons/lucide/x";
import { navClass } from "../utils/nav";
import AdminNavLinks from "./AdminNavLinks.astro";
import SignOutButton from "./SignOutButton.vue";

interface Props {
	user: typeof Astro.locals.user;
	pathname: string;
}

const { user, pathname } = Astro.props;
const isAdmin = user?.role === "admin";
const isDemoUser =
	!!user &&
	import.meta.env.PUBLIC_DEMO_MODE === "true" &&
	user.email === import.meta.env.DEMO_USER_EMAIL;
---

{user && (
		<header class="border-b border-hairline sticky top-0 bg-(--color-canvas) z-50">
			{isDemoUser && (
				<div class="bg-(--color-badge-pending-bg) text-badge-pending-text text-sm text-center px-4 py-2">
					You're viewing a read-only demo account. Changes won't be saved.
				</div>
			)}
			<nav class="max-w-7xl mx-auto px-4 xs:px-6 py-4 flex items-center justify-between gap-4">
				<div class="flex items-center gap-8">
					<a
						href="/dashboard"
						class="font-semibold text-[17px] tracking-tight leading-none select-none"
					>
						lets-talie
					</a>
					<div class="hidden nav:flex items-center gap-1">
						<a
							href="/dashboard"
							class:list={navClass(
								pathname ===
									"/dashboard",
							)}
						>
							Dashboard
						</a>
						<a
							href="/transactions"
							class:list={navClass(
								pathname.startsWith(
									"/transactions",
								),
							)}
						>
							Transactions
						</a>
						<AdminNavLinks
							isAdmin={isAdmin}
							pathname={pathname}
						/>
					</div>
				</div>
				<div class="flex items-center gap-3">
					<span class="hidden nav:block text-sm text-muted truncate max-w-50">
						{user.email}
					</span>
					{/* Dark mode toggle */}
					<button
						id="theme-toggle"
						type="button"
						aria-label="Toggle dark mode"
						class="p-1.5 rounded-full border border-hairline hover:bg-surface transition-colors cursor-pointer text-muted"
					>
						{/* Moon icon (shown in light mode) */}
						<IconMoon id="icon-moon" class="w-4 h-4" aria-hidden="true" />
						{/* Sun icon (shown in dark mode) */}
						<IconSun id="icon-sun" class="w-4 h-4 hidden" aria-hidden="true" />
					</button>
					<SignOutButton client:load />
					{/* Hamburger — visible below 985px */}
					<button
						id="mobile-menu-toggle"
						type="button"
						aria-label="Toggle navigation menu"
						aria-expanded="false"
						aria-controls="mobile-nav"
						class="nav:hidden p-1.5 rounded-full border border-hairline hover:bg-surface transition-colors cursor-pointer text-muted"
					>
						<IconMenu id="icon-hamburger" class="w-4 h-4" aria-hidden="true" />
						<IconX id="icon-close" class="w-4 h-4 hidden" aria-hidden="true" />
					</button>
				</div>
			</nav>
			{/* Mobile nav panel — hidden by default, toggled by hamburger */}
			<div
				id="mobile-nav"
				class="hidden nav:hidden border-t border-hairline"
				aria-hidden="true"
			>
				<div class="max-w-7xl mx-auto px-4 xs:px-6 py-4 flex flex-col gap-1">
					<a
						href="/dashboard"
						class:list={navClass(
							pathname ===
								"/dashboard",
						)}
					>
						Dashboard
					</a>
					<a
						href="/transactions"
						class:list={navClass(
							pathname.startsWith(
								"/transactions",
							),
						)}
					>
						Transactions
					</a>
					{isAdmin && (
						<>
							<a
								href="/users"
								class:list={navClass(
									pathname.startsWith(
										"/users",
									),
								)}
							>
								Users
							</a>
							<a
								href="/transaction-categories"
								class:list={navClass(
									pathname.startsWith(
										"/transaction-categories",
									),
								)}
							>
								Categories
							</a>
							<a
								href="/import-transactions"
								class:list={navClass(
									pathname.startsWith(
										"/import-transactions",
									),
								)}
							>
								Import
							</a>
							<a
								href="/approve-transactions"
								class:list={navClass(
									pathname.startsWith(
										"/approve-transactions",
									),
								)}
							>
								Approve
							</a>
						</>
					)}
					<p class="mt-2 pt-3 border-t border-hairline text-sm text-muted truncate">
						{user.email}
					</p>
				</div>
			</div>
		</header>
	)}

<script is:inline>
	(() => {
		var root = document.documentElement;
		var btn = document.getElementById("theme-toggle");
		var moon = document.getElementById("icon-moon");
		var sun = document.getElementById("icon-sun");

		function applyTheme(theme) {
			root.setAttribute("data-theme", theme);
			localStorage.setItem("theme", theme);
			if (theme === "dark") {
				moon.classList.add("hidden");
				sun.classList.remove("hidden");
			} else {
				sun.classList.add("hidden");
				moon.classList.remove("hidden");
			}
		}

		// Sync icon with current theme on load
		var current = root.getAttribute("data-theme");
		if (!current) {
			current = window.matchMedia("(prefers-color-scheme: dark)").matches
				? "dark"
				: "light";
		}
		if (current === "dark") {
			moon.classList.add("hidden");
			sun.classList.remove("hidden");
		}

		btn.addEventListener("click", () => {
			var next = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
			applyTheme(next);
		});

		// Mobile menu toggle
		var menuBtn = document.getElementById("mobile-menu-toggle");
		var mobileNav = document.getElementById("mobile-nav");
		var hamburgerIcon = document.getElementById("icon-hamburger");
		var closeIcon = document.getElementById("icon-close");

		if (menuBtn && mobileNav) {
			menuBtn.addEventListener("click", () => {
				var isOpen = menuBtn.getAttribute("aria-expanded") === "true";
				if (isOpen) {
					menuBtn.setAttribute("aria-expanded", "false");
					mobileNav.setAttribute("aria-hidden", "true");
					mobileNav.classList.add("hidden");
					hamburgerIcon.classList.remove("hidden");
					closeIcon.classList.add("hidden");
				} else {
					menuBtn.setAttribute("aria-expanded", "true");
					mobileNav.setAttribute("aria-hidden", "false");
					mobileNav.classList.remove("hidden");
					hamburgerIcon.classList.add("hidden");
					closeIcon.classList.remove("hidden");
				}
			});
		}
	})();
</script>
