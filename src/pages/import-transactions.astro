---
import ImportForm from "../components/ImportForm.vue";
import Layout from "../layouts/Layout.astro";
import { fetchUsersAndCategories } from "../lib/queries";

if (!Astro.locals.user) {
	return Astro.redirect("/login");
}

if (Astro.locals.user.role !== "admin") {
	return Astro.redirect("/dashboard");
}

const { users, categories } = await fetchUsersAndCategories();
---

<Layout title="Import Transactions">
	<div class="max-w-5xl mx-auto px-4 xs:px-6 py-10">
		<!-- Header -->
		<div class="mb-8">
			<p class="font-mono text-xs uppercase tracking-widest text-muted mb-2">
				Admin
			</p>
			<h1
				class="text-[clamp(1.75rem,5vw,2.5rem)] font-[340] leading-none tracking-[-0.03em]"
			>
				Import Transactions
			</h1>
			<p class="text-sm text-muted font-[330] mt-2">
				Bulk import transactions from a CSV or JSON file. All rows are validated
				before import — any errors must be fixed first.
			</p>
		</div>

		<!-- Format reference -->
		<div
			class="bg-(--color-block-cream) rounded-2xl px-4 xs:px-6 py-5 mb-8 text-sm"
		>
			<p class="font-mono text-xs uppercase tracking-widest text-muted mb-3">
				Expected format
			</p>
			<div class="overflow-x-auto">
				<table class="text-xs font-mono">
					<thead>
						<tr class="text-left border-b border-hairline">
							<th class="pr-4 pb-2 font-medium">Field</th>
							<th class="pr-4 pb-2 font-medium">Type</th>
							<th class="pb-2 font-medium">Notes</th>
						</tr>
					</thead>
					<tbody class="text-label">
						<tr class="border-b border-hairline">
							<td class="pr-4 py-1.5">name</td>
							<td class="pr-4 py-1.5">string</td>
							<td class="py-1.5">Required</td>
						</tr>
						<tr class="border-b border-hairline">
							<td class="pr-4 py-1.5">date</td>
							<td class="pr-4 py-1.5">string</td>
							<td class="py-1.5">ISO 8601 e.g. 2026-07-01</td>
						</tr>
						<tr class="border-b border-hairline">
							<td class="pr-4 py-1.5">amount</td>
							<td class="pr-4 py-1.5">number</td>
							<td class="py-1.5">Positive decimal</td>
						</tr>
						<tr class="border-b border-hairline">
							<td class="pr-4 py-1.5">paidByUserId</td>
							<td class="pr-4 py-1.5">string</td>
							<td class="py-1.5">User ID or name (partial name allowed)</td>
						</tr>
						<tr class="border-b border-hairline">
							<td class="pr-4 py-1.5">type</td>
							<td class="pr-4 py-1.5">string</td>
							<td class="py-1.5">"deposit" | "withdrawal"</td>
						</tr>
						<tr class="border-b border-hairline">
							<td class="pr-4 py-1.5">status</td>
							<td class="pr-4 py-1.5">string</td>
							<td class="py-1.5">"pending" | "completed" | "cancelled"</td>
						</tr>
						<tr class="border-b border-hairline">
							<td class="pr-4 py-1.5">remarks</td>
							<td class="pr-4 py-1.5">string</td>
							<td class="py-1.5">Optional</td>
						</tr>
						<tr class="border-b border-hairline">
							<td class="pr-4 py-1.5">categoryId</td>
							<td class="pr-4 py-1.5">string</td>
							<td class="py-1.5">Optional — category ID or label</td>
						</tr>
						<tr class="border-b border-hairline">
							<td class="pr-4 py-1.5">transactionGroupId</td>
							<td class="pr-4 py-1.5">string</td>
							<td class="py-1.5">Optional — group key to link rows</td>
						</tr>
						<tr class="border-b border-hairline">
							<td class="pr-4 py-1.5">createdAt</td>
							<td class="pr-4 py-1.5">string</td>
							<td class="py-1.5">Optional — ISO 8601 override</td>
						</tr>
						<tr>
							<td class="pr-4 py-1.5">createdByUserId</td>
							<td class="pr-4 py-1.5">string</td>
							<td class="py-1.5">
								Optional — user ID or name; defaults to the importing admin
							</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>

		<!-- Form -->
		<div class="border border-hairline rounded-2xl p-4 xs:p-6">
			<ImportForm client:load users={users} categories={categories} />
		</div>
	</div>
</Layout>
